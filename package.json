{
  "name": "complgen-syntax",
  "displayName": "complgen-syntax",
  "description": "Compleat/ComplGen Syntax for VSCode",
  "version": "0.1.0",
  "publisher": "moenupa",
  "icon": "icon.png",
  "license": "MIT",
  "homepage": "https://github.com/Moenupa/complgen-syntax",
  "bugs": {
    "url": "https://github.com/Moenupa/complgen-syntax/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Moenupa/complgen-syntax"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "compleat",
    "complgen",
    "completion",
    "textmate",
    "syntax",
    "language support"
  ],
  "contributes": {
    "languages": [
      {
        "id": "compleat",
        "aliases": [
          "compleat",
          "complgen"
        ],
        "extensions": [
          ".usage",
          ".compleat",
          ".complgen"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "compleat",
        "scopeName": "source.usage",
        "path": "./syntaxes/compleat.tmLanguage.json",
        "embeddedLanguages": {
          "source.shell": "shellscript"
        }
      }
    ]
  }
}
