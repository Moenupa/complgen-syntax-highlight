{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "compleat",
  "scopeName": "source.usage",
  "fileTypes": ["compleat", "complgen", "usage"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#assignment-statement"
    },
    {
      "include": "#command-statement"
    },
    {
      "include": "#unknown-statement"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.compleat",
          "begin": "#",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.compleat"
            }
          },
          "end": "(?=$)"
        }
      ]
    },
    "assignment-statement": {
      "name": "meta.statement.assignment.nonterminal.compleat",
      "begin": "(<)([_A-Za-z][\\w-]*)(?:@([_A-Za-z][\\w-]*))?(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.nonterminal.begin.compleat"
        },
        "2": {
          "name": "entity.name.type.nonterminal.compleat"
        },
        "3": {
          "name": "entity.other.attribute-name.target-shell.compleat"
        },
        "4": {
          "name": "punctuation.definition.nonterminal.end.compleat"
        }
      },
      "end": ";",
      "endCaptures": {
        "0": {
          "name": "punctuation.terminator.statement.compleat"
        }
      },
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "include": "#external-command"
        },
        {
          "include": "#strings"
        },
        {
          "include": "#assignment-operator"
        },
        {
          "include": "#literals"
        },
        {
          "include": "#nonterminal-reference"
        },
        {
          "include": "#pattern-operators"
        },
        {
          "include": "#grouping"
        }
      ]
    },
    "command-statement": {
      "name": "meta.statement.command.compleat",
      "begin": "([_A-Za-z][\\w-]*)",
      "beginCaptures": {
        "1": {
          "name": "entity.name.function.command.compleat"
        }
      },
      "end": ";",
      "endCaptures": {
        "0": {
          "name": "punctuation.terminator.statement.compleat"
        }
      },
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "include": "#external-command"
        },
        {
          "include": "#strings"
        },
        {
          "include": "#literals"
        },
        {
          "include": "#nonterminal-reference"
        },
        {
          "include": "#pattern-operators"
        },
        {
          "include": "#grouping"
        },
        {
          "name": "invalid.illegal.assignment.compleat",
          "match": "="
        }
      ]
    },
    "unknown-statement": {
      "name": "meta.statement.invalid.compleat",
      "begin": "(?=\\S)",
      "end": ";",
      "endCaptures": {
        "0": {
          "name": "punctuation.terminator.statement.compleat"
        }
      },
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "include": "#external-command"
        },
        {
          "include": "#strings"
        },
        {
          "include": "#literals"
        },
        {
          "include": "#nonterminal-reference"
        },
        {
          "include": "#pattern-operators"
        },
        {
          "include": "#grouping"
        },
        {
          "name": "invalid.illegal.assignment.compleat",
          "match": "="
        }
      ]
    },
    "external-command": {
      "name": "meta.external-command.compleat",
      "begin": "\\{\\{\\{",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.external-command.begin.compleat"
        }
      },
      "end": "\\}\\}\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.external-command.end.compleat"
        }
      },
      "contentName": "source.shell"
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.compleat",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.compleat"
            }
          },
          "end": "\"|(?=$)",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.compleat"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.compleat",
              "match": "\\\\(?:[\\\\\"nrtbfv]|x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4})"
            },
            {
              "name": "invalid.illegal.escape.compleat",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.compleat",
          "begin": "'",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.compleat"
            }
          },
          "end": "'|(?=$)",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.compleat"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.compleat",
              "match": "\\\\(?:[\\\\'nrtbfv]|x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4})"
            },
            {
              "name": "invalid.illegal.escape.compleat",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.language.any-nonterminal.compleat",
          "match": "(?<![\\w-])<_>(?![\\w-])"
        },
        {
          "name": "constant.language.path-nonterminal.compleat",
          "match": "(?<![\\w-])<(?:PATH|DIRECTORY)>(?![\\w-])"
        },
        {
          "name": "constant.other.option.compleat",
          "match": "(?<![\\w-])--?(\\[no-\\])?[A-Za-z][\\w-]*(?![\\w-])"
        },
        {
          "name": "string.unquoted.atom.compleat",
          "match": "(?<![\\w-])[_A-Za-z][\\w-]*(?![\\w-])"
        }
      ]
    },
    "nonterminal-reference": {
      "patterns": [
        {
          "name": "variable.other.nonterminal.compleat",
          "match": "(<)([_A-Za-z][\\w-]*)(?:@([_A-Za-z][\\w-]*))?(>)",
          "captures": {
            "1": {
              "name": "punctuation.definition.nonterminal.begin.compleat"
            },
            "2": {
              "name": "variable.other.nonterminal.name.compleat"
            },
            "3": {
              "name": "entity.other.attribute-name.target-shell.compleat"
            },
            "4": {
              "name": "punctuation.definition.nonterminal.end.compleat"
            }
          }
        }
      ]
    },
    "assignment-operator": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.compleat",
          "match": "="
        }
      ]
    },
    "pattern-operators": {
      "patterns": [
        {
          "name": "keyword.operator.fallback.compleat",
          "match": "\\|\\|"
        },
        {
          "name": "keyword.operator.alternative.compleat",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.repetition.compleat",
          "match": "\\.\\.\\."
        }
      ]
    },
    "grouping": {
      "patterns": [
        {
          "name": "punctuation.section.group.begin.compleat",
          "match": "\\("
        },
        {
          "name": "punctuation.section.group.end.compleat",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.optional.begin.compleat",
          "match": "\\["
        },
        {
          "name": "punctuation.section.optional.end.compleat",
          "match": "\\]"
        }
      ]
    }
  }
}
